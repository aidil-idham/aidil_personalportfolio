---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects Gallery" sideBarActiveItemID="projects">
  <div class="mt-5 mb-6">
    <h1 class="text-4xl font-bold tracking-tight">Work Produced & Systems Engineering</h1>
    <div class="h-1 w-20 bg-primary mt-2 rounded"></div>
  </div>

  <div class="py-2 prose max-w-none text-base-content/80 text-base mb-6">
    <p>Explore full architectural breakdowns and core production codes for application engines engineered during my academic runtime.</p>
  </div>

  <!-- Interactive Project Cards Matrix -->
  <div class="space-y-6">
    
    <!-- Project Entry 1: TrimTime -->
    <div class="card md:card-side bg-base-200 border border-base-300 shadow-sm overflow-hidden transition-all duration-300 hover:scale-[1.01] hover:shadow-md hover:border-primary/40 group">
      <div class="p-8 flex flex-col justify-between flex-1">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="badge badge-primary font-mono text-xs font-semibold py-2 px-3">FEATURED SYSTEM</span>
            <span class="text-xs opacity-60 font-mono">C++ / MySQL Integration</span>
          </div>
          <h2 class="card-title text-2xl font-bold mb-3 group-hover:text-primary transition-colors">TrimTime Barber Shop Appointment System</h2>
          <p class="text-base-content/75 text-base leading-relaxed mb-4">
            A comprehensive terminal system architecture designed to handle real-time organizational schedules. Implements structural schema validation, concurrent worker timeline shifts, and direct relational database synchronization via SQL runtime execution rules.
          </p>

          <!-- Interactive C++ Terminal Financial Report Widget -->
          <div class="bg-slate-950 rounded-lg p-4 font-mono text-[0.68rem] sm:text-xs text-emerald-400 shadow-inner overflow-x-auto border border-slate-800 mb-6 max-w-full">
            <!-- Terminal Header Controls -->
            <div class="flex gap-1.5 mb-3 border-b border-slate-800 pb-2.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500/80"></div>
              <span class="text-[10px] text-slate-500 ml-2 select-none">trimtime_runtime_v1.0.exe</span>
            </div>
            <!-- Accurate Formatted Terminal Content Split -->
            <pre class="whitespace-pre leading-tight text-emerald-400"><code class="block">============================================================
           MONTHLY FINANCIAL REPORT (JANUARY 2026)
============================================================
  NET PROFIT: RM 4,500.00             TOTAL JOBS: 142
------------------------------------------------------------
 [ PERFORMANCE BY SERVICE ]
 1. Men Haircut      (65%)  #################### 
 2. Shave            (20%)  ######
 3. Hair Treatment   (15%)  ####
------------------------------------------------------------
 [ COMMISSION PAYOUTS ]
 BARBER          GROSS      PAYOUT (60%)     PROFIT (40%)
 idham           RM 20.00   RM 12.00         RM 8.00
------------------------------------------------------------</code></pre>
          </div>
        </div>

        <div class="card-actions justify-between items-center mt-4">
          <div class="flex flex-wrap gap-1.5">
            <span class="badge badge-sm badge-outline opacity-70">Backend Logic</span>
            <span class="badge badge-sm badge-outline opacity-70">Relational Mapping</span>
          </div>
          <a href="/project-deepdive" class="btn btn-sm btn-primary normal-case gap-2 transition-all duration-300 group-hover:translate-x-1">
            Explore Deep Dive Case Study
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Project Entry 2: KBS Expert Advisor -->
    <div class="card md:card-side bg-base-200 border border-base-300 shadow-sm overflow-hidden transition-all duration-300 hover:scale-[1.01] hover:shadow-md hover:border-secondary/40 group">
      <div class="p-8 flex flex-col justify-between flex-1">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="badge badge-secondary font-mono text-xs font-semibold py-2 px-3">KNOWLEDGE BASE</span>
            <span class="text-xs opacity-60 font-mono">CLIPS Runtime Engine</span>
          </div>
          <h2 class="card-title text-2xl font-bold mb-3 group-hover:text-secondary transition-colors">Intelligent Career Path Advisor</h2>
          <p class="text-base-content/75 text-base leading-relaxed mb-4">
            An expert production rules engine engineered using logic strings inside the CLIPS runtime framework. Translates human query variables and qualification metrics into discrete consultative inference trees to guide prospective students into proper computing fields.
          </p>

          <!-- Visual Inference Trace Interface -->
          <div class="bg-slate-950 rounded-lg p-4 font-mono text-[0.68rem] sm:text-xs text-slate-300 border border-slate-800 shadow-inner mb-2 max-w-full">
            <div class="flex items-center justify-between border-b border-slate-800 pb-2 mb-3 text-[10px] text-slate-500 uppercase tracking-widest select-none">
              <span>Inference Engine Status: Active</span>
              <span class="text-secondary">Rules Loaded: 42</span>
            </div>
            
            <div class="space-y-2">
              <div class="flex flex-wrap items-start gap-1">
                <span class="text-secondary font-bold">▶ (defrule check-profile)</span>
                <span class="text-slate-400">If [Skill == SQL] &amp; [Focus == Data_Analysis]</span>
              </div>
              <div class="flex items-start gap-2 pl-4 border-l border-slate-800">
                <span class="text-emerald-400 font-semibold">ASSERT:</span>
                <span class="text-slate-200">"Recommended Path -> Business Intelligence Architect"</span>
              </div>
              <div class="flex items-center gap-2 mt-2 pt-2 border-t border-slate-800/40 text-xs text-emerald-400">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                <span>Confidence Score: 94.8% Match</span>
              </div>
            </div>
          </div>
        </div>

        <div class="card-actions justify-between items-center mt-4">
          <div class="flex flex-wrap gap-1.5">
            <span class="badge badge-sm badge-outline opacity-70">Inference Rules</span>
            <span class="badge badge-sm badge-outline opacity-70">Decision Trees</span>
          </div>
          <span class="text-xs opacity-50 font-mono italic">Academic Repository Asset</span>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
