---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects Gallery" sideBarActiveItemID="projects">
  <div class="mt-5 mb-4">
    <h1 class="text-4xl font-bold">Work Produced & Systems Engineering</h1>
    <div class="h-1 w-20 bg-primary mt-2 rounded"></div>
  </div>

  <div class="py-4 prose max-w-none text-base-content/80 text-lg">
    <p>A directory showcasing standalone system architectures, programmatic tools, and logical applications engineered throughout my academic tenure[cite: 1].</p>
  </div>

  <!-- Project Entry 1 -->
  <HorizontalCard
    title="TrimTime Barber Shop Appointment System"
    img="/post_img.webp"
    desc="A comprehensive console application designed to manage operational workflows. Features multi-module execution tracking, structural data inputs, and database records synchronization built on a C++ core backend engine paired with a relational MySQL database."
    url="/project-deepdive"
    badge="FEATURED CASE STUDY"
  />

  <div class="divider my-4"></div>

  <!-- Project Entry 2 -->
  <HorizontalCard
    title="Intelligent Career Path Advisor"
    img="/post_img.webp"
    desc="A knowledge-based expert consultation system engineered inside the CLIPS runtime environment. Translates structural rule sets and qualification criteria into dynamic advice streams to assist prospective students navigating computing careers."
    url="#"
    badge="KBS PROJECT"
  />
</BaseLayout>
