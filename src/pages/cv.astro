---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLineElement.astro";
---

<BaseLayout title="Academic Journey" sideBarActiveItemID="cv">
  <div class="mt-5 mb-4">
    <div class="text-4xl font-bold">Academic History</div>
    <div class="h-1 w-20 bg-primary mt-2 rounded"></div>
  </div>

  <div class="py-4 prose max-w-none text-base-content/80 text-lg">
    <p>A comprehensive timeline of my academic milestones, institutional foundations, and core technical competencies.</p>
  </div>

  <!-- Timeline Interface Components -->
  <div class="time-line-container grid gap-4 mb-10 mt-4">
    <TimeLineElement
      title="Bachelor of Computer Science (Artificial Intelligence)"
      subtitle="2024 - Present | Universiti Teknikal Malaysia Melaka (UTeM)"
    >
      <div class="text-base text-base-content/70 mt-1">
        Currently studying under the <b>Faculty of Artificial Intelligence and Cyber Security (FAIX)</b>. 
        Focusing on data mapping structures, core algorithmic programming logic, relational query optimizations, 
        and analyzing Human-Computer Interaction interface paradigms.
      </div>
    </TimeLineElement>
    
    <TimeLineElement
      title="Secondary and Pre-University Stream"
      subtitle="Graduated"
    >
      <div class="text-base text-base-content/70 mt-1">
        Developed foundational analytical skills in mathematics, structural logic, and scientific computation templates 
        prior to pursuing specialized computing degrees.
      </div>
    </TimeLineElement>
  </div>

  <!-- Domain Modules Grid Section -->
  <div>
    <div class="text-2xl font-bold mb-4 text-primary">Core Relevant Modules Completed</div>
    <div class="flex flex-wrap gap-3 mb-10">
      <div class="badge badge-lg bg-base-200 border-base-300 p-4 font-medium text-sm">Human-Computer Interaction</div>
      <div class="badge badge-lg bg-base-200 border-base-300 p-4 font-medium text-sm">Database Systems & SQL Normalization</div>
      <div class="badge badge-lg bg-base-200 border-base-300 p-4 font-medium text-sm">Object-Oriented Programming (C++)</div>
      <div class="badge badge-lg bg-base-200 border-base-300 p-4 font-medium text-sm">Knowledge-Based Expert Systems</div>
    </div>
  </div>
</BaseLayout>
