---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="card bg-base-200 border border-base-300/60 shadow-xl overflow-hidden relative group p-8 md:p-12 my-6 transition-all duration-500 hover:shadow-primary/5">
    <div class="absolute -inset-y-0 -right-16 w-32 bg-primary/10 blur-3xl rounded-full transition-all duration-500 group-hover:bg-primary/20 group-hover:scale-150 pointer-events-none"></div>
    
    <div class="relative z-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-success"></span>
        </span>
        <span class="text-xs font-mono tracking-widest uppercase opacity-70">Available for Analytics & Engineering Collaborations</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-2">
        Hi, I'm <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Aidil Idham</span>
      </h1>
      <p class="text-xl font-medium text-base-content/80 mb-6">
        Artificial Intelligence Undergraduate at UTeM
      </p>
      
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="badge badge-md bg-base-300 border-none font-mono py-3 px-4">SQL Data Mapping</span>
        <span class="badge badge-md bg-base-300 border-none font-mono py-3 px-4">C++ & Java Core</span>
        <span class="badge badge-md bg-base-300 border-none font-mono py-3 px-4">Expert Rules Systems</span>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="/projects" class="btn btn-primary px-6 transition-all duration-300 hover:scale-105 shadow-md hover:shadow-primary/20 normal-case">
          View Systems Gallery
        </a>
        <a href="/contact" class="btn btn-outline px-6 transition-all duration-300 hover:scale-105 normal-case">
          Let's Connect
        </a>
      </div>
    </div>
  </div>

  <div class="mt-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold tracking-tight">Technical Core Stack</h2>
      <div class="h-[1px] flex-grow bg-base-300 ml-4"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      
      <div class="bg-base-200/60 backdrop-blur-sm border border-base-300 rounded-xl p-6 shadow-sm hover:border-primary/40 hover:shadow-md transition-all duration-300 group">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[10px] font-mono font-bold uppercase tracking-wider opacity-50">Database Engine</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4m0 5c0 2.21-3.58 4-8 4s-8-1.79-8-4" />
          </svg>
        </div>
        <div class="text-lg font-extrabold text-base-content group-hover:text-primary transition-colors">SQL Architecture</div>
        <p class="text-xs text-base-content/70 mt-2 leading-relaxed">
          Relational scheme blueprints, optimized data manipulation joining, cleansing, and logical view structuring.
        </p>
      </div>

      <div class="bg-base-200/60 backdrop-blur-sm border border-base-300 rounded-xl p-6 shadow-sm hover:border-secondary/40 hover:shadow-md transition-all duration-300 group">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[10px] font-mono font-bold uppercase tracking-wider opacity-50">Data Analytics</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-secondary group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 2 0 002-2V6a2 2 0 002-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="text-lg font-extrabold text-base-content group-hover:text-secondary transition-colors">Power BI & Excel</div>
        <p class="text-xs text-base-content/70 mt-2 leading-relaxed">
          Interactive pipeline modeling, business intelligence key metrics tracking, and diagnostic report structures.
        </p>
      </div>

      <div class="bg-base-200/60 backdrop-blur-sm border border-base-300 rounded-xl p-6 shadow-sm hover:border-accent/40 hover:shadow-md transition-all duration-300 group">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[10px] font-mono font-bold uppercase tracking-wider opacity-50">Core Computing</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <div class="text-lg font-extrabold text-base-content group-hover:text-accent transition-colors">AI Logic Systems</div>
        <p class="text-xs text-base-content/70 mt-2 leading-relaxed">
          Object-oriented design patterns across C++ and Java alongside rules-based consultative expert system modules.
        </p>
      </div>
      
    </div>
  </div>

  <div class="mt-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold tracking-tight">Portfolio Hub Directory</h2>
      <div class="h-[1px] flex-grow bg-base-300 ml-4"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href="/about" class="group bg-base-200 border border-base-300 p-6 rounded-xl transition-all duration-300 hover:scale-[1.03] hover:border-primary hover:shadow-md">
        <div class="text-primary text-2xl mb-2 group-hover:animate-pulse">⚡</div>
        <h3 class="font-bold text-lg mb-1 group-hover:text-primary transition-colors">Personal Qualities</h3>
        <p class="text-sm text-base-content/70 leading-relaxed">Core professional traits, logical frameworks, and my technical skillset matrix.</p>
      </a>

      <a href="/cv" class="group bg-base-200 border border-base-300 p-6 rounded-xl transition-all duration-300 hover:scale-[1.03] hover:border-secondary hover:shadow-md">
        <div class="text-secondary text-2xl mb-2 group-hover:animate-pulse">🎓</div>
        <h3 class="font-bold text-lg mb-1 group-hover:text-secondary transition-colors">Academic History</h3>
        <p class="text-sm text-base-content/70 leading-relaxed">Interactive semester breakdown, completed computing modules, and performance trackers.</p>
      </a>

      <a href="/project-deepdive" class="group bg-base-200 border border-base-300 p-6 rounded-xl transition-all duration-300 hover:scale-[1.03] hover:border-accent hover:shadow-md sm:col-span-2 lg:col-span-1">
        <div class="text-accent text-2xl mb-2 group-hover:animate-pulse">🔬</div>
        <h3 class="font-bold text-lg mb-1 group-hover:text-accent transition-colors">Case Study Deep Dive</h3>
        <p class="text-sm text-base-content/70 leading-relaxed">Detailed architecture walkthrough and video demonstration of my featured systems.</p>
      </a>
    </div>
  </div>
</BaseLayout>
