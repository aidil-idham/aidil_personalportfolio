---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1 text-base-content/80">Hello World, I am</div>
    <div class="text-5xl font-bold text-primary">Aidil Idham Bin Iduros</div>
    <div class="text-3xl py-3 font-semibold text-base-content/70">
      Computer Science (Artificial Intelligence) Student
    </div>
    <div class="py-2">
      <p class="text-lg leading-relaxed">
        Welcome to my digital portfolio. I am an undergraduate student specializing in 
        Artificial Intelligence at the <b>Faculty of Artificial Intelligence and Cyber Security (FAIX), UTeM</b>. 
        This platform showcases my engineering workflows, systems development projects, academic 
        milestones, and human-computer interaction designs.
      </p>
    </div>
    <div class="mt-8 flex gap-4">
      <a class="btn btn-primary" href="/projects"> View My Work </a>
      <a href="/contact" class="btn btn-outline"> Let's Connect </a>
    </div>
  </div>

  <!-- Featured Projects Section Layout -->
  <div class="mt-4 mb-6">
    <div class="text-3xl w-full font-bold">Featured Creations {"</>"}</div>
    <div class="h-1 w-20 bg-primary mt-2 rounded"></div>
  </div>

  <HorizontalCard
    title="TrimTime Barber Shop Appointment System"
    img="/post_img.webp"
    desc="A console application built to optimize business operations. Implements user-interface workflows, normalizes data mapping, and tracks service transaction records using a C++ runtime engine coupled with a relational MySQL database."
    url="/project-deepdive"
    badge="FEATURED"
  />
  
  <div class="divider my-2"></div>
  
  <HorizontalCard
    title="Intelligent Career Path Advisor"
    img="/post_img.webp"
    desc="A knowledge-based expert consultation system developed utilizing the CLIPS environment. It translates complex educational logic paths into programmatic rules to assist prospective students in selecting computing paths."
    url="/projects"
    badge="KBS"
  />
</BaseLayout>
